# Frontend Environment Variables

# API Base URL - Backend REST API endpoint
# Default: http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# Socket.IO Server URL (optional) - WebSocket connection URL
# If not set, will derive from VITE_API_URL or default to http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000
